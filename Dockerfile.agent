# Reusable, worktree-isolated tools image for LearnLoop agents and reviewers.
#
# This image does NOT contain or start MongoDB or RustFS. It provides Python
# 3.11, Node 20, backend dependencies, frontend dependencies, and Playwright
# browsers so that a bind-mounted worktree can run tests without installing
# anything on the host.

FROM node:20-slim

ENV DEBIAN_FRONTEND=noninteractive

# Use the same PyPI mirror as the production backend image for reproducible,
# fast dependency installation in this environment.
ENV UV_INDEX_URL=https://mirrors.bfsu.edu.cn/pypi/web/simple

# Keep uv-managed Python outside /root so it can be made readable by the
# non-root tools service that runs with the host UID/GID.
ENV UV_PYTHON_INSTALL_DIR=/opt/learnloop/uv-python

# Minimal runtime and download dependencies. We prefer prebuilt Python wheels so
# a full compiler toolchain is not required, keeping the image lean.
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ca-certificates \
    libssl-dev \
    && rm -rf /var/lib/apt/lists/*

# Install uv (astral) and make it available system-wide.
RUN curl -LsSf https://astral.sh/uv/install.sh | sh && \
    mv /root/.local/bin/uv /usr/local/bin/uv

# Install Python 3.11 via uv. It lands under UV_PYTHON_INSTALL_DIR.
RUN uv python install 3.11 && \
    ln -sf "$(uv python find 3.11)" /usr/local/bin/python3 && \
    ln -sf /usr/local/bin/python3 /usr/local/bin/python

# Keep all preinstalled dependencies outside /workspace so a worktree bind mount
# cannot hide them.
ENV VIRTUAL_ENV=/opt/learnloop/.venv
ENV UV_FROZEN=1

# Backend dependencies are installed from the lockfile into /opt/learnloop/.venv.
# The project source itself is not copied into the image; it is bind-mounted at
# /workspace at runtime.
WORKDIR /opt/learnloop
COPY backend/pyproject.toml backend/uv.lock backend/README.md ./backend/
RUN cd backend && \
    uv venv --python 3.11 /opt/learnloop/.venv && \
    uv sync --frozen --no-install-project --active --extra dev

# Frontend dependencies are seeded into /opt/learnloop/frontend so they can be
# copied into the per-worktree node_modules volume at runtime.
COPY frontend/package.json frontend/package-lock.json ./frontend/
RUN cd frontend && npm ci

# Preinstall Chromium and its system dependencies for Playwright E2E tests.
RUN cd frontend && npx playwright install --with-deps chromium

# Make Playwright browsers available to the non-root host user at runtime.
# The install step above places them under /root/.cache as root; copy them
# to /opt/learnloop so the tools service can read them with a different UID.
RUN chmod -R a+rX /root/.cache/ms-playwright \
    && cp -a /root/.cache/ms-playwright /opt/learnloop/ms-playwright \
    && chmod -R a+rX /opt/learnloop/ms-playwright
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/learnloop/ms-playwright

# Make the Python venv writable by the non-root host user so uv can install the
# worktree's project package into it at runtime. Everything else only needs to
# be readable/executable.
RUN chmod -R a+rX /opt/learnloop \
    && chmod -R a+w /opt/learnloop/.venv/lib/python3.11/site-packages \
    && chmod a+w /opt/learnloop/.venv/lib/python3.11

# Runtime worktree mount point.
WORKDIR /workspace

ENTRYPOINT []
CMD ["bash"]
