## Shared app runtime settings.
## Docker Compose reuses the MongoDB and S3/RustFS values below for portable local services.
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO

MONGODB_URI=mongodb://localhost:27017/learnloop?replicaSet=rs0&directConnection=true
MONGODB_DATABASE=learnloop

S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=replace-me
S3_SECRET_KEY=replace-me
S3_BUCKET=learnloop-media
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

VLM_ENDPOINT=https://example-vlm-provider.invalid/api
VLM_MODEL=replace-me
VLM_API_KEY=replace-me
VLM_TIMEOUT_SECONDS=120
PREVIEW_EXTRACTING_WINDOW_SECONDS=150

SESSION_COOKIE_NAME=ll_session
SESSION_SECURE=false
SESSION_SAMESITE=lax

## Practice mode configuration
PRACTICE_COOLDOWN_DAYS=7
PRACTICE_LAST_WRONG_WEIGHT=1.0
PRACTICE_FAILURE_RATE_WEIGHT=1.0
PRACTICE_RECENCY_WEIGHT=1.0
